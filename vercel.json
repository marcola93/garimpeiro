{
  "version": 2,
  "builds": [
    { "src": "api/ml.js", "use": "@vercel/node" },
    { "src": "garimpeiro.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ml", "dest": "/api/ml.js" },
    { "src": "/garimpeiro.html", "dest": "/garimpeiro.html" },
    { "src": "/", "dest": "/garimpeiro.html" }
  ]
}
